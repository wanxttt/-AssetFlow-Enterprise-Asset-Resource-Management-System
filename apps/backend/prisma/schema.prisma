datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

// --- ENUMS ---
enum Role {
  ADMIN
  DEPARTMENT_HEAD
  ASSET_MANAGER
  EMPLOYEE
}

enum AssetState {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

// --- MODELS ---
model User {
  id               String       @id @default(uuid())
  email            String       @unique
  password         String
  name             String
  role             Role         @default(EMPLOYEE) // Default per Screen 1 requirements
  isActive         Boolean      @default(true)
  
  departmentId     String?
  department       Department?  @relation("EmployeeDepartment", fields: [departmentId], references: [id])
  headedDepartment Department?  @relation("DepartmentHead")
  
  allocations      Allocation[]
  bookings         Booking[]
  maintenanceReqs  MaintenanceRequest[]
  auditsAssigned   AuditCycle[] @relation("AuditorAssignments")
  
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Department {
  id          String       @id @default(uuid())
  name        String       @unique
  isActive    Boolean      @default(true)
  
  headId      String?      @unique
  head        User?        @relation("DepartmentHead", fields: [headId], references: [id])
  
  parentId    String?
  parent      Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children    Department[] @relation("DepartmentHierarchy")
  
  employees   User[]       @relation("EmployeeDepartment")
  allocations Allocation[]
}

model AssetCategory {
  id          String   @id @default(uuid())
  name        String   @unique // Electronics, Furniture, Vehicles
  description String?
  assets      Asset[]
}

model Asset {
  id              String        @id @default(uuid())
  assetTag        String        @unique // e.g., AF-0001
  name            String
  serialNumber    String?       @unique
  acquisitionDate DateTime?
  acquisitionCost Float?
  condition       String?
  location        String?
  isBookable      Boolean       @default(false)
  status          AssetState    @default(AVAILABLE)
  
  categoryId      String
  category        AssetCategory @relation(fields: [categoryId], references: [id])
  
  allocations     Allocation[]
  bookings        Booking[]
  maintenance     MaintenanceRequest[]
  auditRecords    AuditRecord[]
}

model Allocation {
  id             String    @id @default(uuid())
  assetId        String
  asset          Asset     @relation(fields: [assetId], references: [id])
  
  userId         String?
  user           User?     @relation(fields: [userId], references: [id])
  
  departmentId   String?
  department     Department? @relation(fields: [departmentId], references: [id])
  
  allocatedAt    DateTime  @default(now())
  expectedReturn DateTime?
  returnedAt     DateTime?
  returnNotes    String?
  
  status         String    @default("ACTIVE") // ACTIVE, RETURNED, TRANSFER_PENDING
}

model Booking {
  id        String   @id @default(uuid())
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id])
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  startTime DateTime
  endTime   DateTime
  status    String   @default("UPCOMING") // UPCOMING, ONGOING, COMPLETED, CANCELLED
}

model MaintenanceRequest {
  id          String   @id @default(uuid())
  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id])
  
  requesterId String
  requester   User     @relation(fields: [requesterId], references: [id])
  
  description String
  priority    String   // LOW, MEDIUM, HIGH
  status      String   @default("PENDING") // PENDING, APPROVED, IN_PROGRESS, RESOLVED
  
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?
}

model AuditCycle {
  id        String        @id @default(uuid())
  name      String        // e.g., Q3 Engineering Audit
  startDate DateTime
  endDate   DateTime
  status    String        @default("OPEN") // OPEN, CLOSED
  
  auditors  User[]        @relation("AuditorAssignments")
  records   AuditRecord[]
}

model AuditRecord {
  id           String     @id @default(uuid())
  auditCycleId String
  auditCycle   AuditCycle @relation(fields: [auditCycleId], references: [id])
  
  assetId      String
  asset        Asset      @relation(fields: [assetId], references: [id])
  
  status       String     // VERIFIED, MISSING, DAMAGED
  notes        String?
}